# AlphaESS Open API credentials — from https://open.alphaess.com
# Leave blank to run in DEMO mode with simulated data.
ALPHAESS_APP_ID=
ALPHAESS_APP_SECRET=

# Your system serial number (inverter SN). If blank, the first system
# bound to your developer account is used automatically.
ALPHAESS_SYS_SN=AL7021025112659

# Seconds between live-data polls (AlphaESS allows getLastPowerData
# at most once every 10s; 30s is polite and plenty).
POLL_INTERVAL=30

# Force demo mode even if credentials are set (true/false)
DEMO_MODE=
